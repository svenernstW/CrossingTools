Package: CrossingTools
Title: Tools for Cross Optimization in Plant Breeding Programs
Version: 1.0.5
Authors@R: 
    c(
      person("Sven", "Weber", email = "sven.e.weber@agrar.uni-giessen.de", role = c("aut", "cre")),
      person("Daniel", "Tolhurst", role = "aut"),
