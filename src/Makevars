CXX_STD = CXX17

# RcppParallel include/compile flags (oneTBB)
PKG_CPPFLAGS = $(RCPP_PARALLEL_CPPFLAGS)
PKG_CXXFLAGS = $(RCPP_PARALLEL_CXXFLAGS) $(SHLIB_OPENMP_CXXFLAGS)

# Link RcppParallel (pulls in oneTBB). OpenMP LDFLAGS expand to empty on macOS.
PKG_LIBS = $(RCPP_PARALLEL_LIBS) $(SHLIB_OPENMP_LDFLAGS) \
           $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)
