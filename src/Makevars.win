# Use C++17
CXX_STD = CXX17

# RcppParallel (TBB)
PKG_CPPFLAGS = $(RCPP_PARALLEL_CPPFLAGS)

# Use R’s OpenMP macros (don’t hard-code -fopenmp)
PKG_CXXFLAGS = $(SHLIB_OPENMP_CXXFLAGS) $(RCPP_PARALLEL_CXXFLAGS)

# Linker flags: OpenMP (if available), RcppParallel, BLAS/LAPACK
PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS) $(SHLIB_OPENMP_LDFLAGS) \
           $(RCPP_PARALLEL_LIBS) \
           $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS)
