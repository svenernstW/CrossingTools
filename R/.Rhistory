crosses      = cbind(crosses, crosses),  # shape 4 cols for DH four/three-way fn
genetic.map  = map,
M            = M,
U            = U,
t            = 0,
intensity    = 1,
covariance   = FALSE
)
crosses <- matrix(c(1,2, 3,4), byrow = TRUE, ncol = 2)
# call one of your functions
