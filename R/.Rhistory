library(CrossingTools)
set.seed(1)
# toy data
M <- matrix(sample(c(0,2), 20, TRUE), nrow = 5)
U <- matrix(rnorm(ncol(M)*3), ncol = 3)
map <- data.frame(site = 1:ncol(M), chr = c(1,1,2,2), pos = c(0,10,0,10))
map
# call one of your functions
