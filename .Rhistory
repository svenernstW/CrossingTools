library(AlphaSimR)
library(sommer)
n_parents <- 30
n_crosses <- 60
n_ind <- 20
nQTL <- 1000
HSQ <- 0.5
founderPop <- runMacs2(
nInd = n_parents,#number of founder individuals
nChr = 10,#number of chromosomes
bp = 68364505,#physical size of a chromosome
genLen = 1.6766,#genetic size of a chromosome
mutRate = 2 * 10e-9,# mutation rate, I quess leaving it as it is should be fine
segSites = 2000,#segregating sites per chromosmes, i.e. loci varying with their alleles withhin the population
ploidy = 2,#ploidy level, unless working with an autopolypoid leave at 2, allopolyploids mostly act as diploids
inbred = T,
Ne = 100
)
SP = SimParam$new(founderPop)
SP$addTraitA(nQtlPerChr=nQTL)
SP$setVarE(h2 = HSQ) #defines the heritability for the trait
SP$addSnpChip(nSnpPerChr = 1000,#number of SNPs per chromosome
name = "10k")#defines the name of the array
library(CrossingTools)
library(AlphaSimR)
# Generate initial haplotypes
founderPop = runMacs(nInd     = 100,
nChr     = 10,
segSites = 400 + 400,
inbred   = TRUE,
species  = "WHEAT")
SP = SimParam$new(founderPop)
# Add SNP chip
SP$restrSegSites(400, 400)
if (400 > 0) {
SP$addSnpChip(400)
}
# Add traits
SP$addTraitA(nQtlPerChr = 400,
mean       = 0,
var        = 1)
pop = newPop(founderPop)
# Add phenotype reflecting evaluation in EYT
pop = setPheno(pop,H2 = 0.5)
rm(founderPop)
# ---- Burn-in phase: Phenotypic selection program ----
cat("--> Working on Burn-in \n")
for(year in 1:10) {
cat(" Working on burn-in year:",year,"\n")
pop <-
selectCross(
pop,
nInd = 100,
nCrosses = 100,
selectTop = TRUE,
use = "pheno"
)
pop <- makeDH(pop, nDH = 20)
pop <- setPheno(pop, H2 = 0.5)
}
# Initialize model on the latest DHs tested at end of burn-in
ans <- RRBLUP(pop, use = "pheno")
ans
ans[[1]]
ans@bv
ans@bv[[1]]
ans@bv[[1]]@addEff
ans@gv[[1]]@addEff
plot(ans@gv[[1]]@addEff,ans@bv[[1]]@addEff)
CrossPlan <- t(combn(sample(1:nInd(pop),100),2))[sample(1:4950,100),]
M <- (pullQtlGeno(pop))
GenMap <- getQtlMap()
GenMap$site <- 1:nrow(GenMap)
u <- ans@bv[[1]]@addEff
# Initialize model on the latest DHs tested at end of burn-in
ans <- RRBLUP(pop, use = "pheno",snpChip = 1)
M <- (pullSnpGeno(pop))
GenMap <- getSnpMap()
GenMap$site <- 1:nrow(GenMap)
u <- ans@bv[[1]]@addEff
u
segvar <- calculate_variances_DH(crosses = CrossPlan,genetic.map = GenMap,M = M,U = u,t = 0,intensity = 1,covariance = F,method = "osthushenrich")
segvar
crossmean <- mean(segvar$EGBV1)
crossmean
pop <- makeCross(pop = pop,crossPlan = as.matrix(CrossPlan))
pop <- makeDH(pop, nDH = 100)
expvar <- mean(segvar$var1) + mean((segvar$EGBV1 - crossmean)^2)
results_gs[[i]] <- data.frame(meanG = meanG(pop), varG=varG(pop),expmeanG=crossmean,expvarG = expvar)
results_gs <- list()
results_gs[[i]] <- data.frame(meanG = meanG(pop), varG=varG(pop),expmeanG=crossmean,expvarG = expvar)
data.frame(meanG = meanG(pop), varG=varG(pop),expmeanG=crossmean,expvarG = expvar)
results_gs <- list()
for(i in 1:20){
# Generate initial haplotypes
founderPop = runMacs(nInd     = 100,
nChr     = 10,
segSites = 400 + 400,
inbred   = TRUE,
species  = "WHEAT")
SP = SimParam$new(founderPop)
# Add SNP chip
SP$restrSegSites(400, 400)
if (400 > 0) {
SP$addSnpChip(400)
}
# Add traits
SP$addTraitA(nQtlPerChr = 400,
mean       = 0,
var        = 1)
pop = newPop(founderPop)
# Add phenotype reflecting evaluation in EYT
pop = setPheno(pop,H2 = 0.5)
rm(founderPop)
# ---- Burn-in phase: Phenotypic selection program ----
cat("--> Working on Burn-in \n")
for(year in 1:10) {
cat(" Working on burn-in year:",year,"\n")
pop <-
selectCross(
pop,
nInd = 100,
nCrosses = 100,
selectTop = TRUE,
use = "pheno"
)
pop <- makeDH(pop, nDH = 20)
pop <- setPheno(pop, H2 = 0.5)
}
# Initialize model on the latest DHs tested at end of burn-in
ans <- RRBLUP(pop, use = "pheno",snpChip = 1)
CrossPlan <- t(combn(sample(1:nInd(pop),100),2))[sample(1:4950,100),]
M <- (pullSnpGeno(pop))
GenMap <- getSnpMap()
GenMap$site <- 1:nrow(GenMap)
u <- ans@bv[[1]]@addEff
segvar <- calculate_variances_DH(crosses = CrossPlan,genetic.map = GenMap,M = M,U = u,t = 0,intensity = 1,covariance = F,method = "osthushenrich")
crossmean <- mean(segvar$EGBV1)
pop <- makeCross(pop = pop,crossPlan = as.matrix(CrossPlan))
pop <- makeDH(pop, nDH = 100)
expvar <- mean(segvar$var1) + mean((segvar$EGBV1 - crossmean)^2)
results_gs[[i]] <- data.frame(meanG = meanG(pop), varG=varG(pop),expmeanG=crossmean,expvarG = expvar)
}
results_gs.df <- do.call(rbind,results_gs)
plot(results_gs.df$meanG,results_gs.df$expmeanG)
cor(results_gs.df$meanG,results_gs.df$expmeanG)
plot(results_gs.df$Trait1,results_gs.df$expvarG)
cor(results_gs.df$Trait1,results_gs.df$expvarG)
