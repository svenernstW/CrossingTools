# calculate desired gains index, this will return the desired gains index
# for each individual, as well as the resulting trait weights
gains <- rep(10,n_trait) # we want to improve all traits to the same ammount
DG <-calculate_desired_gains(A = A, # Breeding values
use.V.approx = T,#alternativly one can use the marginal Trait covariance matrix of the blups as in Werner et al. the approx option uses a emperical method for it which is simply cov(A)
gains = gains) # desired gains
DG$index
DG$weight
# Define a simple two-chromosome map with evenly spaced markersin Morgan
map <- data.frame(
site = 1:n_mark,
chr  = rep(1:2, each = n_mark / 2),
pos  = c(seq(0, 1.5, length.out = n_mark / 2),
seq(0, 1.5, length.out = n_mark / 2))
)
# Generate all possible pairwise crosses among the individuals.
# This scales as O(n^2) and can become large in realistic populations.
crosses <- t(combn(n_ind, 2))
out_dh <- calculate_variances_DH(
crosses         = crosses,
genetic.map     = map,       # must contain site, chr, and pos covering all M columns
M               = M,         # genotype matrix (0/2 coding)
U               = U,         # additive marker effects (markers x traits)
t               = 2,         # random-mating generations before DH creation
intensity       = 1,         # selection differential for SPV
covariance      = TRUE,      # include segregation covariance matrices
calculate.index = TRUE,      # should and index be formed?
weights = DG$weight ,        # trait weights for the index
method          = "osthushenrich"
)
# The cross_values component is a data.frame summarizing per-cross statistics:
#  * EGBV: Expected Genetic Breeding Value per trait
#  * var: Genetic variance of segregating progeny per trait
#  * SPV: Superior Progeny Value (expected selection gain per cross)
head(out_dh$cross_values)
# If covariance = TRUE, each cross includes a trait covariance matrix.
# The following example shows the first cross (trait x trait covariance):
out_dh$covariances[[1]]
# The index component is a data.frame summarizing per-cross statistics:
#  * EGBV: Expected Genetic Breeding Value for the index
#  * var: Genetic variance of segregating progeny for the index
#  * SPV: Superior Progeny Value (expected selection gain per cross) for the index
head(out_dh$index)
out_ril <- calculate_variances_RIL(
crosses         = crosses,
genetic.map     = map,
M               = M,
U               = U,
t               = 2,
intensity       = 1,
covariance      = TRUE,
calculate.index = TRUE,      # should and index be formed?
weights = DG$weight ,        # trait weights for the index
method          = "osthushenrich"
)
# Summarize the results
head(out_ril$cross_values)
# Inspect the first covariance matrix (trait x trait)
out_ril$covariances[[1]]
# Summarize the index
head(out_ril$index)
# Summarize the results
head(out_ril$cross_values)
# Inspect the first covariance matrix (trait x trait)
out_ril$covariances[[1]]
# Summarize the index
head(out_ril$index)
