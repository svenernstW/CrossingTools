library(CrossingTools)
n_ind   <- 20   # number of individuals
n_mark  <- 200  # number of markers
n_trait <- 3    # number of traits
# Generate a diploid genotype matrix (0 = AA, 2 = BB)
M <- matrix(sample(c(0, 2), n_ind * n_mark, replace = TRUE), nrow = n_ind)
# Simulate additive marker effects for all traits (markers x traits)
U <- matrix(rnorm(n_mark * n_trait), ncol = n_trait)
M %*% U
GV <- M %*% U
# calculate desired gains index, this will return the desired gains index
# for each individual, as well as the resulting trait weights
gains <- rep(10,n_trait) # we want to improve all traits to the same ammount
DG <-calculate_desired_gains(A = A, # Breeding values
use.V.approx = T,#alternativly one can use the marginal Trait covariance matrix of the blups as in Werner et al. the approx option uses a emperical method for it which is simply cov(A)
gains = gains) # desired gains
A <- M %*% U
# calculate desired gains index, this will return the desired gains index
# for each individual, as well as the resulting trait weights
gains <- rep(10,n_trait) # we want to improve all traits to the same ammount
DG <-calculate_desired_gains(A = A, # Breeding values
use.V.approx = T,#alternativly one can use the marginal Trait covariance matrix of the blups as in Werner et al. the approx option uses a emperical method for it which is simply cov(A)
gains = gains) # desired gains
DG$index
DG$weight
# calculate desired gains index, this will return the desired gains index
# for each individual, as well as the resulting trait weights
gains <- rep(100,n_trait) # we want to improve all traits to the same ammount
DG <-calculate_desired_gains(A = A, # Breeding values
use.V.approx = T,#alternativly one can use the marginal Trait covariance matrix of the blups as in Werner et al. the approx option uses a emperical method for it which is simply cov(A)
gains = gains) # desired gains
DG$index
