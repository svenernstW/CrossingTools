# --- 3) Try devtools first (happy path) --------------------------------------
ok <- TRUE
outpdf <- NA_character_
tryCatch({
outpdf <- devtools::build_manual(path = "builds")   # path MUST be a directory
message("Built via devtools: ", outpdf)
}, error = function(e) {
message("devtools::build_manual() failed: ", conditionMessage(e))
ok <<- FALSE
})
# --- 4) If devtools fails, call R CMD Rd2pdf directly (prints real TeX error) -
if (!ok) {
rbin <- file.path(R.home("bin"), "R.exe")
args <- c("CMD", "Rd2pdf", "-o", "builds/CrossingTools-manual.pdf", ".")
# Capture output so you can see the first '!' error line
logf <- "builds/Rd2pdf_log.txt"
status <- system2(rbin, args, stdout = logf, stderr = logf)
cat("R CMD Rd2pdf exit status:", status, "\n")
cat("---- First 80 lines of log ----\n")
cat(readLines(logf, n = 80), sep = "\n")
if (status == 0) {
outpdf <- normalizePath("builds/CrossingTools-manual.pdf", winslash = "/")
message("Built via R CMD Rd2pdf: ", outpdf)
ok <- TRUE
}
}
# --- 5) If still failing, 99% of the time it's one of these -------------------
if (!ok) {
message("\nLikely causes & quick fixes:\n",
"1) Unescaped LaTeX specials in roxygen (wrap identifiers in backticks: `a_b`, `p%`).\n",
"2) Non-UTF-8 characters: DESCRIPTION should have 'Encoding: UTF-8'.\n",
"3) Missing Rd macros: if you use Rdpack macros, add 'Suggests: Rdpack' and 'RdMacros: Rdpack'.\n",
"4) Examples calling suggested pkgs: guard with @examplesIf requireNamespace(..., quietly = TRUE) or \\donttest{}.\n",
"5) Missing LaTeX package: the log will say which .sty to install; use tinytex::tlmgr_install('packagename').\n")
}
# Search roxygen (R/) and any already-generated Rd (man/)
sym_pat <- "[\u2264\u2265\u00B1\u00D7\u221E\u03BC\u2013\u2014]"  # ≤ ≥ ± × ∞ μ – —
scan_files <- c(
list.files("R", pattern = "\\.[rR]$", full.names = TRUE, recursive = TRUE),
list.files("man", pattern = "\\.Rd$", full.names = TRUE, recursive = TRUE)
)
for (f in scan_files) {
ln <- readLines(f, warn = FALSE, encoding = "UTF-8")
hits <- grep(sym_pat, ln)
if (length(hits)) {
cat("\n==>", f, "\n")
for (h in hits) cat(sprintf("  L%-4d %s\n", h, ln[h]))
}
}
